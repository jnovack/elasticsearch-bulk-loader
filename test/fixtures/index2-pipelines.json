{
  "e2e-index2-enrich": {
    "description": "Enrich target documents from the source index enrich policy",
    "processors": [
      {
        "enrich": {
          "policy_name": "e2e-source-policy",
          "field": "lookup_id",
          "target_field": "source_enrich",
          "max_matches": 1,
          "ignore_missing": false
        }
      }
    ]
  },
  "e2e-index2-secondary": {
    "description": "Secondary target pipeline that is not the default pipeline",
    "processors": [
      {
        "set": {
          "field": "secondary_pipeline_ran",
          "value": true
        }
      }
    ]
  }
}
